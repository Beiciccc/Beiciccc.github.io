---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { type Lang, htmlLang, ui } from '../i18n/content';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  /** Absolute path of the equivalent page in the other language (for the lang toggle). */
  altUrl: string;
  /** Optional canonical/og path for this page (defaults to Astro.url.pathname). */
  path?: string;
  /** Active nav key for aria-current. */
  active?: 'home' | 'blog';
}

const { lang, title, description, altUrl, active } = Astro.props;
const t = ui[lang];

// Single source of truth: the `site` value from astro.config.mjs (lowercase
// host, matching the GitHub Pages domain). Falls back to the lowercase literal
// only if Astro.site is somehow unset.
const siteUrl = Astro.site?.href ?? 'https://beiciccc.github.io/';
const canonical = new URL(Astro.url.pathname, siteUrl).href;
// Social cards must be raster: X/Twitter, Facebook, LinkedIn, Slack, Discord,
// iMessage do NOT render SVG OpenGraph images. Use the 1200×630 PNG.
const ogImage = new URL('/og-default.png', siteUrl).href;

// The other language's canonical URL for hreflang alternates.
const altCanonical = new URL(altUrl, siteUrl).href;
const enHref = lang === 'en' ? canonical : altCanonical;
const zhHref = lang === 'zh' ? canonical : altCanonical;
---

<!doctype html>
<html lang={htmlLang(lang)} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Kun Zhang" />
    <link rel="canonical" href={canonical} />

    <!-- hreflang alternates so EN/ZH versions cross-reference cleanly. -->
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="zh-Hans" href={zhHref} />
    <link rel="alternate" hreflang="x-default" href={enHref} />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_GB'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Type: SYSTEM font stack only (defined in global.css). No embedded
         proprietary fonts, no external font requests. -->

    <!-- No-JS fallback: if scripting is off, reveal-on-scroll content must stay
         fully visible (covers .reveal and the .reveal--scale variant). -->
    <noscript>
      <style>
        .reveal, .reveal--scale { opacity: 1 !important; transform: none !important; }
      </style>
    </noscript>

    <!-- No-flash bootstrap: mark JS-enabled + set data-theme before first paint.
         `.js` on <html> is what lets the CSS hide .reveal only when JS can
         animate it back in (progressive enhancement). -->
    <script is:inline>
      (function () {
        document.documentElement.classList.add('js');
        try {
          var stored = localStorage.getItem('theme');
          var theme =
            stored ||
            (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          /* localStorage unavailable — fall back to the light default already on <html>. */
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">{t.skipToContent}</a>
    <Header lang={lang} altUrl={altUrl} active={active} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />

    <!-- Theme + language toggle behaviour (progressively enhanced). -->
    <script is:inline>
      (function () {
        var root = document.documentElement;

        // THEME toggle
        var themeBtn = document.getElementById('theme-toggle');
        function syncThemeBtn() {
          if (!themeBtn) return;
          // Icon visibility is handled purely by CSS keyed off [data-theme] on
          // <html> (set before first paint), so there is no JS icon swap/flash.
          // JS only keeps the a11y pressed-state in sync with the theme.
          var isDark = root.getAttribute('data-theme') === 'dark';
          themeBtn.setAttribute('aria-pressed', String(isDark));
        }
        if (themeBtn) {
          syncThemeBtn();
          themeBtn.addEventListener('click', function () {
            var next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            root.setAttribute('data-theme', next);
            try {
              localStorage.setItem('theme', next);
            } catch (e) {}
            syncThemeBtn();
          });
        }
      })();
    </script>

    <!-- Scroll-reveal (IntersectionObserver) + frosted-nav scrolled state.
         Vanilla, reduced-motion-guarded. No-JS fallback lives in <head>. -->
    <script is:inline>
      (function () {
        var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var els = document.querySelectorAll('.reveal');

        // Reduced motion or no IO support: show everything, skip animation.
        if (reduce || !('IntersectionObserver' in window)) {
          els.forEach(function (el) { el.classList.add('is-visible'); });
        } else {
          var io = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (e) {
                if (e.isIntersecting) {
                  e.target.classList.add('is-visible');
                  io.unobserve(e.target);
                }
              });
            },
            { rootMargin: '0px 0px -10% 0px', threshold: 0.12 }
          );
          els.forEach(function (el) { io.observe(el); });
        }

        // Frosted-nav: settle the sticky bar once scrolled past a small threshold.
        var onScroll = function () {
          document.body.classList.toggle('scrolled', window.scrollY > 8);
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });

        // Optional very-subtle hero scale-on-scroll. Gated on reduced motion:
        // when reduced motion is preferred, never write --hero-scale.
        var hero = document.querySelector('.hero--parallax');
        if (hero && !reduce) {
          var onHero = function () {
            var s = Math.max(0.965, 1 - window.scrollY / 4200);
            hero.style.setProperty('--hero-scale', s.toFixed(4));
          };
          onHero();
          window.addEventListener('scroll', onHero, { passive: true });
        }
      })();
    </script>
  </body>
</html>

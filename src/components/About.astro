---
import { type Lang } from '../i18n/content';
import { Content as AboutEn } from '../content_data/about.en.md';
import { Content as AboutZh } from '../content_data/about.zh.md';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const heading = lang === 'zh' ? '关于' : 'About';
const eyebrow = lang === 'zh' ? '简介' : 'About';
---

<section id="about" class="section section--bleed section--tint" aria-labelledby="about-heading">
  <div class="about__inner">
    <div class="about__head section--center reveal">
      <p class="section-mark">{eyebrow}</p>
      <h2 id="about-heading">{heading}</h2>
    </div>
    <div class="about__body prose reveal">
      {lang === 'en' ? <AboutEn /> : <AboutZh />}
    </div>
  </div>
</section>

<style>
  .about__head {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .about__body {
    margin-left: auto;
    margin-right: auto;
    max-width: 68ch;
  }
  .about__body :global(p) {
    color: var(--text);
    font-size: clamp(1.18rem, 1.8vw, 1.45rem);
    line-height: 1.5;
    letter-spacing: -0.012em;
  }
  :global(:lang(zh)) .about__body {
    max-width: 40em;
  }
  :global(:lang(zh)) .about__body :global(p) {
    line-height: 1.75;
  }
</style>

---
import { type Lang, research, pick } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const r = pick(research, lang);
const eyebrow = lang === 'zh' ? '研究' : 'Research';
---

<section id="research" class="section section--center" aria-labelledby="research-heading">
  <div class="research__head reveal">
    <p class="section-mark">{eyebrow}</p>
    <h2 id="research-heading">{r.heading}</h2>
    <p class="lede research__intro">{r.intro}</p>
  </div>

  <div class="grid research__grid reveal-stagger">
    {
      r.items.map((item, i) => (
        <article class="card research__card reveal" style={`--i:${i}`}>
          <span class="research__icon" aria-hidden="true">{item.icon}</span>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))
    }
  </div>
</section>

<style>
  .research__head {
    margin-bottom: clamp(2.2rem, 4vw, 3.2rem);
  }
  .research__intro {
    max-width: 64ch;
  }
  /* Cards carry left-aligned content even inside the centered section. */
  .research__grid {
    text-align: left;
  }
  .research__card h3 {
    margin-top: 0.6rem;
  }
  .research__card p {
    margin-bottom: 0;
  }
</style>

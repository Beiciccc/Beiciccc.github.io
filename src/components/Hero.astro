---
import { type Lang, hero, pick } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const h = pick(hero, lang);
---

<section class="section hero hero--parallax" aria-labelledby="hero-name">
  <div class="hero__head reveal reveal--scale" style="--i:0">
    <span class="eyebrow">{h.kicker}</span>
    <h1 id="hero-name">{h.name}</h1>
    <p class="hero__tagline">{h.tagline}</p>
    <p class="lede">{h.intro}</p>
  </div>
  <div class="hero__actions reveal reveal--scale" style="--i:1">
    <a class="btn" href={h.ctaPrimary.href}>
      {h.ctaPrimary.label}
      <span class="btn__arrow" aria-hidden="true">→</span>
    </a>
    <a class="btn btn--ghost" href={h.ctaSecondary.href} target="_blank" rel="noopener">
      {h.ctaSecondary.label}
      <span aria-hidden="true">↗</span>
    </a>
  </div>
</section>

<style>
  /* Center the tagline within the Apple-style centered hero column. */
  .hero__tagline {
    font-size: clamp(1.3rem, 2.4vw, 1.75rem);
    line-height: 1.3;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text);
    max-width: 24ch;
    margin: 0.4rem auto 1.1rem;
    text-wrap: balance;
    background: linear-gradient(120deg, var(--text-strong), var(--accent));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  :global(:lang(zh)) .hero__tagline {
    max-width: 30ch;
    line-height: 1.45;
  }
</style>
